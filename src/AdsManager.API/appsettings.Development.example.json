{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "PATCH",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Tenant-Id",
      "X-Trace-Id"
    ],
    "AllowCredentials": true
  },
  "Cache": {
    "Provider": "Memory",
    "DashboardTtlSeconds": 120,
    "ReportTtlSeconds": 120,
    "Redis": {
      "ConnectionString": "localhost:6379",
      "InstanceName": "adsmanager-dev",
      "DefaultTtlSeconds": 120
    }
  },
  "DataRetention": {
    "ApiLogsDays": 30,
    "AuditLogsDays": 180,
    "RuleExecutionLogsDays": 90,
    "SyncJobRunsDays": 90,
    "InsightDaily": {
      "Enabled": false,
      "Mode": "None",
      "GlobalRetentionDays": null,
      "TenantPolicies": []
    }
  },
  "Observability": {
    "EnablePrometheus": true,
    "MetricsEndpoint": "/metrics"
  }
}
